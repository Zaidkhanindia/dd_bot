<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dd_bot">

  <xacro:property name="chassis_length" value="0.6"/>
  <xacro:property name="chassis_width" value="0.4"/>
  <xacro:property name="chassis_height" value="0.2"/>
  <xacro:property name="chassis_mass" value="130.0"/>

  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_thickness" value="0.05"/>
  <xacro:property name="wheel_mass" value="4.25"/>
  <xacro:property name="wheel_separation" value="0.45"/> <!-- Width + wheel thickness -->

  <xacro:property name="caster_radius" value="0.05"/>
  <xacro:property name="caster_mass" value="1.42"/>

  <!-- Base Link (Chassis) -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${chassis_mass}"/>
      <inertia ixx="2.168" ixy="0" ixz="0" iyy="4.336" iyz="0" izz="5.637"/>
    </inertial>
  </link>

  <!-- Right Wheel Link -->
  <link name="right_wheel_link">
    <visual>
      <origin rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.0115" ixy="0" ixz="0" iyy="0.0213" iyz="0" izz="0.0115"/>
    </inertial>
  </link>

  <!-- Left Wheel Link -->
  <link name="left_wheel_link">
    <visual>
      <origin rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="${wheel_mass}"/>
      <inertia ixx="0.0115" ixy="0" ixz="0" iyy="0.0213" iyz="0" izz="0.0115"/>
    </inertial>
  </link>

  <!-- Caster Wheel Link -->
  <link name="caster_wheel_link">
      <visual>
        <geometry>
            <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="grey">
            <color rgba="0.5 0.5 0.5 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
            <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${caster_mass}"/>
        <inertia ixx="0.00142" ixy="0" ixz="0" iyy="0.00142" iyz="0" izz="0.00142"/>
      </inertial>
  </link>

  <!-- Right Wheel Joint -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="0 -${wheel_separation/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Left Wheel Joint -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="0 ${wheel_separation/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Caster Wheel Joint -->
  <joint name="caster_wheel_joint" type="fixed">
      <parent link="base_link"/>
      <child link="caster_wheel_link"/>
      <origin xyz="0.25 0 -${chassis_height/2 - caster_radius}"/>
  </joint>

  <!--<gazebo>
    <plugin
      filename="gz::sim::systems::DiffDrive"
      name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
       This is the Gazebo Transport topic the plugin will listen to
      <topic>/model/dd_bot/cmd_vel</topic>
    </plugin>
  </gazebo> -->

  <!-- Gazebo DiffDrive plugin -->
  <gazebo>
    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">

      <!-- Wheel joint names -->
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <!-- Wheel separation & radius -->
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>

      <!-- Command topic (Gazebo Transport) -->
      <topic>/model/dd_bot/cmd_vel</topic>

      <!-- Odometry output topic -->
      <odometry_topic>/model/dd_bot/odometry</odometry_topic>

      <!-- Frame names -->
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>

      <!-- Enable odometry publication -->
      <publish_odom>true</publish_odom>
      <publish_tf>false</publish_tf>

    </plugin>
  </gazebo>

</robot>